# Database (optional - for production)
DATABASE_URL=postgresql://user:password@localhost:5432/ecommerce

# Production environment
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# AWS S3 (optional - for image CDN)
USE_S3=False
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_STORAGE_BUCKET_NAME=your-bucket-name
AWS_S3_REGION_NAME=us-east-1

# Stripe Payment Keys
STRIPE_SECRET_KEY=sk_test_your_test_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_test_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# EasyPaisa Configuration (optional)
EASYPAISA_STORE_ID=your_easypaisa_store_id
EASYPAISA_USERNAME=your_easypaisa_username
EASYPAISA_PASSWORD=your_easypaisa_password

# Bank transfer configuration (optional)
BANK_NAME=Your Bank Name
ACCOUNT_HOLDER=Your Business Name
ACCOUNT_NUMBER=1234567890
IBAN=PK12345678901234567890
SWIFT_CODE=BANKPKKA

# Email Configuration (optional - for order confirmations)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DEFAULT_FROM_EMAIL=no-reply@eshopdeluxe.com
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
